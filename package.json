{
  "name": "ts-hkt",
  "version": "0.1.0",
  "description": "A minimal toolkit for higher-kinded types in TypeScript.",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "typescript",
    "hkt",
    "higher-kinded-types",
    "types"
  ]
}
